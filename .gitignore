# ─────────────────────────────────────────────
# NoyoSafe - .gitignore
# Se sube todo (data/, outputs/, modelos .pt) salvo cache y entorno local.
# ─────────────────────────────────────────────

# Entorno virtual (se reconstruye con requirements.txt, no se versiona)
venv/
env/

# Cache de Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Cache de Jupyter
.ipynb_checkpoints/

# Cache de labels de Ultralytics (se regenera solo al entrenar/validar)
*.cache

# VSCode (config local del editor)
.vscode/

# Windows
Thumbs.db
Desktop.ini